# Local dev: Vite proxies /api and /ws to localhost:8080 (see vite.config.ts).
VITE_API_URL=http://localhost:8080/api/v1

# Optional override for WebSocket base; if unset, derived from VITE_API_URL in production builds.
# VITE_WS_URL=https://pharmacy-hafj.onrender.com

# Must match where users open the SPA (backend uses this for email links: verify-email, reset-password).
# Set the same value as backend APP_FRONTEND_BASE_URL in production.
# VITE_PUBLIC_APP_URL=http://localhost:5173
